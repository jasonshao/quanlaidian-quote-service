# QUOTE_API_BASE_URL=https://<your-api-host>
# QUOTE_DATA_ROOT=data
# QUOTE_FILE_TTL_DAYS=7
# QUOTE_LOG_LEVEL=INFO

# Pricing baseline (required in production)
# PRICING_BASELINE_KEY decrypts references/pricing_baseline_v5.obf at runtime.
# PRICING_BASELINE_STRICT=1 refuses plaintext fallback — recommended for prod.
# PRICING_BASELINE_KEY=
# PRICING_BASELINE_STRICT=0
